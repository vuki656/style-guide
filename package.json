{
    "name": "@dvukovic/style-guide",
    "version": "0.27.0",
    "description": "My own style guide",
    "repository": {
        "type": "git",
        "url": "https://github.com/vuki656/style-guide"
    },
    "license": "MIT",
    "author": {
        "name": "Domagoj Vukovic"
    },
    "type": "module",
    "exports": {
        "./cspell": {
            "types": "./dist/cspell/index.d.ts",
            "default": "./src/cspell/index.js"
        },
        "./cspell/base.txt": "./src/cspell/base.txt",
        "./eslint": {
            "types": "./dist/eslint/index.d.ts",
            "default": "./src/eslint/index.js"
        },
        "./knip": {
            "types": "./src/knip/index.d.ts",
            "default": "./src/knip/index.js"
        },
        "./prettier": {
            "types": "./dist/prettier/index.d.ts",
            "default": "./src/prettier/index.js"
        },
        "./stylelint": {
            "types": "./dist/stylelint/index.d.ts",
            "default": "./src/stylelint/index.js"
        }
    },
    "bin": "./src/cli/index.js",
    "files": [
        "dist",
        "src/cli",
        "src/cspell",
        "src/eslint",
        "src/knip",
        "src/package-json",
        "src/prettier",
        "src/stylelint",
        "!**/*.test.js",
        "!**/*.test.ts"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.build.json",
        "lint": "yarn lint:eslint && yarn lint:prettier && yarn lint:stylelint && yarn lint:cspell && yarn lint:knip",
        "lint:cspell": "cspell --no-progress --no-summary --unique '**'",
        "lint:eslint": "eslint . --cache --concurrency=auto",
        "lint:fix": "yarn lint:eslint --fix && yarn lint:prettier --write && yarn lint:stylelint --fix && yarn lint:cspell && yarn lint:knip",
        "lint:knip": "knip",
        "lint:prettier": "prettier --check --cache .",
        "lint:stylelint": "stylelint ./**/*.css --cache",
        "release": "release-it",
        "test": "vitest run"
    },
    "dependencies": {
        "@clack/prompts": "1.7.0",
        "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
        "@eslint/config-helpers": "0.6.0",
        "@next/eslint-plugin-next": "16.2.10",
        "@stylistic/eslint-plugin": "5.10.0",
        "@tanstack/eslint-plugin-query": "5.101.2",
        "@typescript-eslint/parser": "8.63.0",
        "@vitest/eslint-plugin": "1.6.23",
        "eslint-plugin-array-func": "5.1.1",
        "eslint-plugin-baseline-js": "0.7.0",
        "eslint-plugin-import-x": "4.17.1",
        "eslint-plugin-jest": "29.15.4",
        "eslint-plugin-mobx": "0.0.14",
        "eslint-plugin-n": "18.2.2",
        "eslint-plugin-package-json": "1.5.0",
        "eslint-plugin-perfectionist": "5.10.0",
        "eslint-plugin-playwright": "2.10.5",
        "eslint-plugin-promise": "7.3.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.1.1",
        "eslint-plugin-security-node": "1.1.4",
        "eslint-plugin-sonarjs": "4.1.0",
        "eslint-plugin-storybook": "10.5.0",
        "eslint-plugin-turbo": "2.10.4",
        "eslint-plugin-unicorn": "71.1.0",
        "eslint-plugin-unused-imports": "4.4.1",
        "globals": "17.7.0",
        "jsonc-eslint-parser": "3.1.0",
        "postcss-resolve-nested-selector": "0.1.6",
        "postcss-selector-parser": "7.1.4",
        "prettier-plugin-embed": "0.5.1",
        "prettier-plugin-jsdoc": "1.8.1",
        "prettier-plugin-packagejson": "3.0.2",
        "prettier-plugin-prisma": "5.0.0",
        "prettier-plugin-sh": "0.19.0",
        "prettier-plugin-sql": "0.20.0",
        "prettier-plugin-tailwindcss": "0.8.0",
        "prettier-plugin-toml": "2.0.6",
        "stylelint-order": "8.1.1",
        "typescript-eslint": "8.63.0"
    },
    "devDependencies": {
        "@release-it/conventional-changelog": "11.0.1",
        "@types/node": "26.1.1",
        "@types/semver": "7.7.1",
        "cspell": "10.0.1",
        "eslint": "10.7.0",
        "knip": "6.26.0",
        "prettier": "3.9.5",
        "release-it": "20.2.1",
        "semver": "7.8.5",
        "storybook": "10.5.0",
        "stylelint": "17.14.0",
        "typescript": "6.0.3",
        "vitest": "4.1.10"
    },
    "peerDependencies": {
        "cspell": "10",
        "eslint": "^9 || ^10",
        "knip": ">=5",
        "prettier": "3",
        "stylelint": ">=16",
        "typescript": "5 || 6"
    },
    "peerDependenciesMeta": {
        "cspell": {
            "optional": true
        },
        "eslint": {
            "optional": true
        },
        "knip": {
            "optional": true
        },
        "prettier": {
            "optional": true
        },
        "stylelint": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    "packageManager": "yarn@4.14.1",
    "engines": {
        "node": ">=24.0.0"
    },
    "volta": {
        "node": "24.18.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    }
}
